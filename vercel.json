{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "nodeVersion": "22.x",
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server.cjs"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
